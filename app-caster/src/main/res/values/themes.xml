<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      The DeviceDefault parent maps to Material 3 on Android 12+ devices, the
      only world this app runs in (min/target SDK 36). The splash background
      uses the system's dynamic Material You neutral palette so the pre-Compose
      window matches the wallpaper-derived surface the app renders in.
    -->
    <style name="Theme.Caster" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:windowSplashScreenBackground">@android:color/system_neutral1_50</item>
    </style>
</resources>
