<?xml version="1.0" encoding="utf-8"?>
<!--
    The private SSH key (filesDir/id_ed25519) grants shell access to the build
    host. It must never leave the device. allowBackup="false" already disables
    cloud and adb backup; these rules additionally exclude every file and
    preference from Android 12+ device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
